# Copy to .env.local for local dev, or set these in Vercel environment variables for production.

# Local SQLite (dev)
# DATABASE_URL="file:./dev.db"

# Turso (production) — get these from https://turso.tech
DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Vercel Blob — set automatically by Vercel when you add the Blob store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
