# Copy to .env.local for local dev, or set these in Vercel environment variables for production.

# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (dev)
# DATABASE_URL="file:./dev.db"

# Turso (production) — get these from https://turso.tech
DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Set automatically by Vercel when you connect a Blob store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Authentication ────────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-min-32-chars"
AUTH_USERNAME="admin"
AUTH_PASSWORD="change-me-to-a-strong-password"
