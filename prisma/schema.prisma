generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Client {
  id        String       @id @default(cuid())
  name      String
  phone     String
  source    String       @default("STORE")
  orders    Order[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([name])
  @@map("clients")
}

model Product {
  id            String         @id @default(cuid())
  name          String
  description   String?
  salePrice     Float
  orderProducts OrderProduct[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("products")
}

model PaymentType {
  id        String   @id @default(cuid())
  name      String   @unique
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_types")
}

model OrderStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_statuses")
}

model Order {
  id            String         @id @default(cuid())
  orderNumber   Int            @unique
  orderDate     DateTime
  client        Client         @relation(fields: [clientId], references: [id])
  clientId      String
  paymentType   PaymentType    @relation(fields: [paymentTypeId], references: [id])
  paymentTypeId String
  status        OrderStatus    @relation(fields: [statusId], references: [id])
  statusId      String
  totalValue    Float
  advanceAmount Float          @default(0)
  deliveryFee   Float          @default(0)
  pickupHour    String?
  notes         String?
  deliveryNotes String?
  photos        OrderPhoto[]
  orderProducts OrderProduct[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([orderDate])
  @@index([clientId])
  @@index([statusId])
  @@map("orders")
}

model OrderProduct {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int     @default(1)

  @@map("order_products")
}

model OrderPhoto {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  filePath  String
  createdAt DateTime @default(now())

  @@map("order_photos")
}
